<section id="tools" class="s-tools" data-intersect>
  <div class="s-tools__header">
    <span class="s-tools__label">02 — Skills</span>
    <h2 class="s-tools__title">Tools <em>&amp;</em> Tech</h2>
  </div>
  <div class="s-tools__scroll">
    <div class="s-tools__track js-tools-track"></div>
  </div>
</section>

<script>
  const tools = [
    { name: '3ds Max',       svg: `<svg viewBox="0 0 24 24"><text x="1" y="13" font-size="9" font-weight="900" font-family="monospace" fill="#160000">3ds</text><text x="1" y="22" font-size="7" font-weight="700" font-family="monospace" fill="#160000">MAX</text></svg>` },
