    { name: 'UML',           svg: `<svg viewBox="0 0 24 24"><text x="0" y="16" font-size="10" font-weight="700" font-family="monospace" fill="#160000">UML</text></svg>` },
    { name: 'VS Code',       svg: `<svg viewBox="0 0 24 24"><path fill="#160000" d="M23.15 2.587L18.21.21a1.494 1.494 0 0 0-1.705.29l-9.46 8.63-4.12-3.128a.999.999 0 0 0-1.276.057L.327 7.261A1 1 0 0 0 .326 8.74L3.899 12 .326 15.26a1 1 0 0 0 .001 1.479L1.65 17.94a.999.999 0 0 0 1.276.057l4.12-3.128 9.46 8.63a1.492 1.492 0 0 0 1.704.29l4.942-2.377A1.5 1.5 0 0 0 24 19.841V4.16a1.5 1.5 0 0 0-.85-1.573zm-5.146 14.861L10.826 12l7.178-5.448v10.896z"/></svg>` },
    { name: 'Git',           svg: `<svg viewBox="0 0 24 24"><path fill="#160000" d="M23.546 10.93L13.067.452c-.604-.603-1.582-.603-2.188 0L8.708 2.627l2.76 2.76c.645-.215 1.379-.07 1.889.441.516.515.658 1.258.438 1.9l2.658 2.66c.645-.223 1.387-.078 1.9.435.721.72.721 1.884 0 2.604-.719.719-1.881.719-2.6 0-.539-.541-.674-1.337-.404-1.996L12.86 8.955v6.525c.176.086.342.203.488.348.713.721.713 1.883 0 2.6-.719.721-1.889.721-2.609 0-.719-.719-.719-1.879 0-2.598.182-.18.387-.316.605-.406V8.835c-.217-.091-.424-.222-.6-.401-.545-.545-.676-1.342-.396-2.009L7.636 3.67 .45 10.881c-.6.605-.6 1.584 0 2.189l10.48 10.477c.604.604 1.582.604 2.186 0l10.43-10.43c.605-.603.605-1.582 0-2.187"/></svg>` },
    { name: 'GitHub',        svg: `<svg viewBox="0 0 24 24"><path fill="#160000" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>` },
    { name: 'Canva',         svg: `<svg viewBox="0 0 24 24"><path fill="#160000" d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm3.9 14.7c-.6 1.5-2.1 2.7-3.9 2.7-2.4 0-4.2-1.8-4.2-4.2S9.6 9 12 9c1.8 0 3.3 1.05 3.9 2.55.15.3.03.66-.27.81-.3.15-.66.03-.81-.27C14.4 10.8 13.29 10.2 12 10.2c-1.65 0-3 1.35-3 3s1.35 3 3 3c1.29 0 2.4-.63 2.82-1.59.15-.3.51-.45.81-.3.3.15.45.51.27.81v-.42z"/></svg>` },
    { name: 'WordPress',     svg: `<svg viewBox="0 0 24 24"><path fill="#160000" d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zM2.084 12c0-1.335.259-2.608.725-3.775l3.992 10.946A9.928 9.928 0 0 1 2.084 12zm9.916 9.916a9.956 9.956 0 0 1-2.75-.385l2.921-8.489 2.993 8.2a.96.96 0 0 0 .073.141 9.95 9.95 0 0 1-3.237.533zm1.351-14.372c.59-.031 1.121-.093 1.121-.093.528-.062.466-.838-.062-.807 0 0-1.586.125-2.609.125-1.058 0-2.644-.125-2.644-.125-.528-.031-.59.776-.062.807 0 0 .5.062 1.028.093l1.527 4.184-2.144 6.427-3.567-10.611c.59-.031 1.121-.093 1.121-.093.528-.062.466-.838-.062-.807 0 0-1.586.125-2.609.125-.183 0-.4-.004-.629-.012A9.923 9.923 0 0 1 12 2.084c2.549 0 4.877.957 6.625 2.526-.042-.003-.083-.008-.126-.008-1.059 0-1.808.921-1.808 1.91 0 .887.512 1.636 1.057 2.525.41.714.887 1.636.887 2.957 0 .918-.353 1.983-.818 3.466l-1.073 3.583-3.889-11.499zm3.74 13.282l2.981-8.617c.557-1.393.743-2.508.743-3.5 0-.36-.024-.694-.067-1.011A9.929 9.929 0 0 1 21.916 12c0 3.771-2.088 7.062-5.175 8.754l-.65-1.928z"/></svg>` },
  ]

  const W = 120, H = 139

  function makeHex(tool: { name: string; svg: string }) {
    const hex = document.createElement('div')
    hex.className = 'st-hex'
    hex.style.width  = W + 'px'
    hex.style.height = H + 'px'
    hex.innerHTML = `
      <div class="hc st-hex__base"></div>
      <div class="hc st-hex__side st-hex__s14"></div>
      <div class="hc st-hex__side st-hex__s13"></div>
      <div class="hc st-hex__side st-hex__s12"></div>
      <div class="hc st-hex__side st-hex__s11"></div>
      <div class="hc st-hex__side st-hex__s10"></div>
      <div class="hc st-hex__side st-hex__s9"></div>
      <div class="hc st-hex__side st-hex__s8"></div>
      <div class="hc st-hex__side st-hex__s7"></div>
      <div class="hc st-hex__side st-hex__s6"></div>
      <div class="hc st-hex__side st-hex__s5"></div>
      <div class="hc st-hex__side st-hex__s4"></div>
      <div class="hc st-hex__side st-hex__s3"></div>
      <div class="hc st-hex__side st-hex__s2"></div>
      <div class="hc st-hex__side st-hex__s1"></div>
      <div class="st-hex__top">
        <div class="hc st-hex__top-fill"></div>
        <div class="hc st-hex__top-shine"></div>
        <div class="st-hex__icon">${tool.svg}</div>
      </div>
      <div class="st-hex__tip">${tool.name}</div>
    `

    hex.addEventListener('click', () => {
      if (hex.classList.contains('is-flying')) return
      hex.classList.add('is-flying')
      hex.addEventListener('animationend', () => {
        hex.classList.remove('is-flying')
        hex.style.opacity = '0.12'
      }, { once: true })
    })

    return hex
  }

  function init() {
    const track = document.querySelector('.js-tools-track') as HTMLElement
    if (!track) return

    const ROWS    = 4
    const PER_ROW = 24  // enough to fill any screen with no visible end
    
    function shuffle(arr) {
      return [...arr].sort(() => Math.random() - 0.5)
    }
    for (let r = 0; r < ROWS; r++) {
      const row = document.createElement('div')
      row.className = 'st-hex-row'
      if (r % 2 === 1) row.style.paddingLeft = (W / 2) + 'px'

      const filled: typeof tools = []
      while (filled.length < PER_ROW) filled.push(...shuffle(tools))
      const slice = filled.slice(0, PER_ROW)

      ;[...slice, ...slice].forEach(t => row.appendChild(makeHex(t)))
      track.appendChild(row)
    }

    track.addEventListener('mouseenter', () => track.classList.add('is-paused'))
    track.addEventListener('mouseleave', () => track.classList.remove('is-paused'))
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init)
  } else {
    init()
  }
</script>

<style lang="scss">
  .s-tools {
    position: relative;
    z-index: 1;  /* below s-work so work can slide over it */
    overflow: hidden;
    padding: 8rem 0 10rem;
    background: color(primary);

    &::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 1px;
      background: color(secondary);
      opacity: 0.15;
    }
  }

  .s-tools__header {
    position: absolute;
    top: 3.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    text-align: center;
    pointer-events: none;
  }

  .s-tools__label {
    display: block;
    margin-bottom: 0.4rem;
    font: 700 12px / 24px font-family(fraktion);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color(secondary);
    opacity: 0.3;
  }

  .s-tools__title {
    margin: 0;
    font: 200 clamp(2.5rem, 5vw, 4rem) / 1 font-family(editorial);
    letter-spacing: -0.01em;
    color: color(secondary);

    em {
      font-style: italic;
      color: #F40C3F;
    }
  }

  .s-tools__scroll {
    overflow: hidden;
    transform: rotate(-10deg) skewX(-3deg);
    transform-origin: center center;
    margin: 0 -12rem;
    padding: 4rem 0 6rem;
    mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 5%, black 95%, transparent 100%);
  }

  .s-tools__track {
    display: flex;
    flex-direction: column;
    width: max-content;
    animation: st-scroll 50s linear infinite;

    &.is-paused { animation-play-state: paused; }
  }

  @keyframes st-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  :global(.st-hex-row) {
    display: flex;
    align-items: flex-start;
    margin-bottom: -36px;
  }

  :global(.st-hex) {
    position: relative;
    flex-shrink: 0;
    cursor: pointer;
    opacity: 0.12;
    transition: opacity 0.35s ease, filter 0.3s ease;

    &:hover {
      opacity: 1;
      z-index: 100;
      filter: drop-shadow(0 20px 35px rgba(0,0,0,0.4))
              drop-shadow(0 4px 10px rgba(22,0,0,0.35));
    }

    &.is-flying {
      animation: st-fly 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards !important;
      opacity: 1 !important;
      z-index: 200;
      pointer-events: none;
    }
  }

  @keyframes st-fly {
    0%   { transform: translateY(0)     scale(1);    opacity: 1; }
    60%  { transform: translateY(-90px) scale(1.08); opacity: 1; }
    100% { transform: translateY(-160px) scale(0.7); opacity: 0; }
  }

  :global(.hc) {
    clip-path: polygon(50% 0%,100% 25%,100% 75%,50% 100%,0% 75%,0% 25%);
  }

  :global(.st-hex__base) { position: absolute; inset: 0; background: #111; z-index: 0; }
  :global(.st-hex__side) { position: absolute; inset: 0; z-index: 1; }

  :global(.st-hex__s14) { background: #0e0e0e; transform: translateY(0px);   z-index: 6;  }
  :global(.st-hex__s13) { background: #111111; transform: translateY(-1px);  z-index: 7;  }
  :global(.st-hex__s12) { background: #141414; transform: translateY(-2px);  z-index: 8;  }
  :global(.st-hex__s11) { background: #171717; transform: translateY(-3px);  z-index: 9;  }
  :global(.st-hex__s10) { background: #1a1a1a; transform: translateY(-4px);  z-index: 10; }
  :global(.st-hex__s9)  { background: #1d1d1d; transform: translateY(-5px);  z-index: 11; }
  :global(.st-hex__s8)  { background: #202020; transform: translateY(-6px);  z-index: 12; }
  :global(.st-hex__s7)  { background: #232323; transform: translateY(-7px);  z-index: 13; }
  :global(.st-hex__s6)  { background: #272727; transform: translateY(-8px);  z-index: 14; }
  :global(.st-hex__s5)  { background: #2b2b2b; transform: translateY(-9px);  z-index: 15; }
  :global(.st-hex__s4)  { background: #2f2f2f; transform: translateY(-10px); z-index: 16; }
  :global(.st-hex__s3)  { background: #333333; transform: translateY(-11px); z-index: 17; }
  :global(.st-hex__s2)  { background: #373737; transform: translateY(-12px); z-index: 18; }
  :global(.st-hex__s1)  { background: #3b3b3b; transform: translateY(-13px); z-index: 19; }

  :global(.st-hex__top) {
    position: absolute; inset: 0; z-index: 20;
    display: flex; align-items: center; justify-content: center;
    transform: translateY(-14px);
    transition: transform 0.3s cubic-bezier(0.22,1,0.36,1);
  }
  :global(.st-hex__top-fill) {
    position: absolute; inset: 0;
    background: linear-gradient(145deg, #ffffff 0%, #f0ecec 40%, #e0d8d8 100%);
    transition: background 0.3s;
  }
  :global(.st-hex__top-shine) {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(125deg,
      rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.3) 30%,
      transparent 55%, rgba(0,0,0,0.06) 100%);
  }
  :global(.st-hex__icon) {
    position: relative; z-index: 2;
    width: 50px; height: 50px;
    display: flex; align-items: center; justify-content: center;
    transition: filter 0.3s;
  }
  :global(.st-hex__icon svg) { width: 36px; height: 36px; }

  /* hover — ink (#160000) sides, no purple */
  :global(.st-hex:hover .st-hex__top)      { transform: translateY(-28px); }
  :global(.st-hex:hover .st-hex__top-fill) {
    background: linear-gradient(145deg, #ffffff 0%, #f5f0f0 40%, #ede6e6 100%);
  }

  :global(.st-hex:hover .st-hex__s14) { background: #160000; }
  :global(.st-hex:hover .st-hex__s13) { background: #1b0000; }
  :global(.st-hex:hover .st-hex__s12) { background: #200000; }
  :global(.st-hex:hover .st-hex__s11) { background: #250000; }
  :global(.st-hex:hover .st-hex__s10) { background: #2a0000; }
  :global(.st-hex:hover .st-hex__s9)  { background: #2f0000; }
  :global(.st-hex:hover .st-hex__s8)  { background: #350000; }
  :global(.st-hex:hover .st-hex__s7)  { background: #3b0000; }
  :global(.st-hex:hover .st-hex__s6)  { background: #410000; }
  :global(.st-hex:hover .st-hex__s5)  { background: #470000; }
  :global(.st-hex:hover .st-hex__s4)  { background: #4e0000; }
  :global(.st-hex:hover .st-hex__s3)  { background: #550000; }
  :global(.st-hex:hover .st-hex__s2)  { background: #5c0000; }
  :global(.st-hex:hover .st-hex__s1)  { background: #640000; }

  :global(.st-hex:hover .st-hex__icon) {
    filter: drop-shadow(0 0 6px rgba(22,0,0,0.5));
    animation: st-glitch 0.35s steps(2) 1;
  }

  @keyframes st-glitch {
    0%   { transform: translateX(0); }
    25%  { transform: translateX(-3px); filter: drop-shadow(3px 0 0 #F40C3F) drop-shadow(-3px 0 0 #160000); }
    50%  { transform: translateX(3px); }
    75%  { transform: translateX(-1px); }
    100% { transform: translateX(0); }
  }

  :global(.st-hex__tip) {
    position: absolute;
    bottom: calc(100% - 10px); left: 50%;
    transform: translateX(-50%) translateY(-20px) rotate(10deg) skewX(3deg);
    background: #160000;
    color: #f0e6e6;
    font: 700 7px / 1 font-family(fraktion);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 4px 9px;
    white-space: nowrap;
    opacity: 0; pointer-events: none;
