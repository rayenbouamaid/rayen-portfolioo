---
const { class: className } = Astro.props
import rayenSrc   from '../assets/rayen.jpg'
import rayenv2Src from '../assets/rayenv2.png'
---

<a-waves class:list={className} data-intersect>
  <canvas class="js-canvas"></canvas>

  <div class="photo-wrap">
    <div class="js-photo-card-wrap photo-card-wrap">

      <div class="photo-card js-card">
        <!-- img1 = real photo (rayen.jpg) — revealed on hover -->
        <img src={rayenSrc.src}   alt="Rayen Bouamaid" class="photo-img photo-img--real" />
        <!-- img2 = v2 (rayenv2.png) — default, visible at rest -->
        <img src={rayenv2Src.src} alt=""               class="photo-img photo-img--v2" />
        <!-- dissolve canvas sits on top of both, draws opaque blocks over img1 to hide it -->
        <canvas class="photo-dissolve js-dissolve"></canvas>
        <div class="photo-glare js-glare"></div>
      </div>

      <div class="photo-border"></div>

      <div class="photo-terminal js-terminal">
        <div class="terminal__header">
          <span class="terminal__dot terminal__dot--dark"></span>
          <span class="terminal__dot terminal__dot--dark"></span>
          <span class="terminal__dot terminal__dot--red"></span>
          <span class="terminal__title">ID_CARD.exe</span>
        </div>
        <div class="terminal__body">
          <div class="terminal__line">
            <span class="terminal__prompt">$</span>
            <span class="terminal__key">NAME</span>
            <span class="terminal__sep">::</span>
            <span class="terminal__val js-type-name"></span><span class="terminal__cursor">▮</span>
          </div>
          <div class="terminal__line">
            <span class="terminal__prompt">$</span>
            <span class="terminal__key">AGE</span>
            <span class="terminal__sep">::</span>
            <span class="terminal__val">22</span>
          </div>
          <div class="terminal__line terminal__line--status">
            <span class="terminal__prompt">$</span>
            <span class="terminal__key">STATUS</span>
            <span class="terminal__sep">::</span>
            <span class="terminal__val terminal__val--accent">
              <span class="terminal__blink"></span>OPEN_TO_WORK
            </span>
          </div>
          <div class="terminal__line terminal__line--dim">
            <span class="terminal__prompt">#</span>
            <span class="terminal__comment">// rayen-portfolio.dev</span>
          </div>
        </div>
        <div class="terminal__scanlines"></div>
      </div>

    </div>
  </div>
</a-waves>

<script>
  import Emitter from '../utils/Emitter'

  class AWaves extends HTMLElement {
    canvas: HTMLCanvasElement
    ctx: CanvasRenderingContext2D
    bounding: { width: number; height: number }
    mouse: { x: number; y: number; active: boolean }
    particles: any[]
    isInteractive: boolean
    isPaused: boolean

    wrap: HTMLElement
    card: HTMLElement
    glare: HTMLElement
    dissolveCanvas: HTMLCanvasElement
    dissolveCtx: CanvasRenderingContext2D
    imgReal: HTMLImageElement
    imgV2: HTMLImageElement
    typeName: HTMLElement

    tiltX: number
    tiltY: number
    glitchIntensity: number
    attractIntensity: number
    isHoveringCard: boolean
    cardRect: DOMRect | null
    typewriterDone: boolean

    // Dissolve: 0 = v2 fully shown, 1 = real fully shown
    revealProgress: number
    dissolvePixels: number[]
    dissolveW: number
    dissolveH: number
    readonly PIXEL_SIZE = 8

    readonly COUNT = 150
    readonly CONNECT_DIST = 140
    readonly MOUSE_DIST = 150
    readonly MAX_TILT = 18
    readonly CARD_CONNECT_DIST = 90
    readonly ATTRACT_RADIUS = 320
    readonly ATTRACT_FORCE = 0.012
    readonly FULL_NAME = 'RAYEN_BOUAMAID'

    connectedCallback() {
      this.canvas        = this.querySelector('.js-canvas')
      this.ctx           = this.canvas.getContext('2d')
      this.wrap          = this.querySelector('.js-photo-card-wrap')
      this.card          = this.querySelector('.js-card')
      this.glare         = this.querySelector('.js-glare')
      this.dissolveCanvas = this.querySelector('.js-dissolve')
      this.dissolveCtx   = this.dissolveCanvas.getContext('2d')
      this.imgReal       = this.querySelector('.photo-img--real')
      this.imgV2         = this.querySelector('.photo-img--v2')
      this.typeName      = this.querySelector('.js-type-name')

      this.mouse            = { x: -999, y: -999, active: false }
      this.particles        = []
      this.isInteractive    = false
      this.isPaused         = true
      this.tiltX            = 0
      this.tiltY            = 0
      this.glitchIntensity  = 0
      this.attractIntensity = 0
      this.isHoveringCard   = false
      this.cardRect         = null
      this.typewriterDone   = false
      this.revealProgress   = 0
      this.dissolvePixels   = []
      this.dissolveW        = 0
      this.dissolveH        = 0

      // At rest: v2 on top, real hidden beneath
      // dissolveCanvas starts fully opaque over img--real,
      // so we only see v2. But actually: img--v2 is z:2, img--real z:1.
      // dissolveCanvas is z:3. At progress=0 it's clear (we see v2 on top).
      // At progress=1 it draws opaque blocks over v2... wait, we need the opposite.
      //
      // Correct stacking:
      //   z1: img--real  (always there)
      //   z2: img--v2    (fades out via opacity as progress rises)
      //   z3: dissolveCanvas (draws the pixel wipe ON TOP of v2 as it fades)
      //
      // So: progress 0 = v2 fully opaque (we see v2)
      //     progress 1 = v2 opacity 0 (we see real)
      // dissolveCanvas draws the animated mask during transition.

      // Hide immediately so there's no flash before the entry animation
      this.wrap.style.opacity = '0'

      this.setSize()
      this.spawnParticles()
      this.buildDissolveMap()
      this.bindEvents()

      // Entry flip — fires after intro is fully gone
      // Use a direct style.animation so Astro scoping never interferes
      document.addEventListener('intro', () => {
        // 900ms = intro slide-up duration, then we play our animation
        setTimeout(() => {
          this.wrap.style.opacity   = '1'
          this.wrap.style.animation = 'card-entry 1s cubic-bezier(0.22, 1, 0.36, 1) both'
          this.wrap.addEventListener('animationend', () => {
            this.wrap.style.animation = ''
            this.wrap.style.transform = 'perspective(900px) rotateX(0deg) rotateY(0deg) scale(1)'
          }, { once: true })
        }, 1500)
      }, { once: true })
    }

    buildDissolveMap() {
      const pw = this.PIXEL_SIZE
      const cw = this.card.offsetWidth  || 240
      const ch = this.card.offsetHeight || 256
      this.dissolveW = Math.ceil(cw / pw)
      this.dissolveH = Math.ceil(ch / pw)
      const total = this.dissolveW * this.dissolveH
      const arr   = Array.from({ length: total }, (_, i) => i)
      // Fisher-Yates shuffle
      for (let i = total - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1))
        ;[arr[i], arr[j]] = [arr[j], arr[i]]
      }
      this.dissolvePixels = arr
    }

    bindEvents() {
      Emitter.on('resize', this.onResize, this)
      this.addEventListener('mousemove',  this.onMouseMove.bind(this))
      this.addEventListener('touchmove',  this.onTouchMove.bind(this))
      this.addEventListener('mouseleave', () => {
        this.mouse.active   = false
        this.mouse.x        = -999
        this.mouse.y        = -999
        this.isHoveringCard = false
      })
      this.addEventListener('intersect', this.onIntersect.bind(this), { passive: true })
      this.addEventListener('introend',  () => { this.isInteractive = true })
    }

    onResize() {
      this.setSize()
      this.spawnParticles()
      this.buildDissolveMap()
      this.cardRect = null
    }

    onMouseMove(e: MouseEvent) {
      if (!this.isInteractive) return
      const rect   = this.getBoundingClientRect()
      this.mouse.x = e.clientX - rect.left
      this.mouse.y = e.clientY - rect.top
      this.mouse.active = true

      if (!this.cardRect) this.cardRect = this.wrap.getBoundingClientRect()
      const cr = this.cardRect
      this.isHoveringCard = (
        e.clientX >= cr.left && e.clientX <= cr.right &&
        e.clientY >= cr.top  && e.clientY <= cr.bottom
      )

      if (this.isHoveringCard) {
        const cardRect = this.card.getBoundingClientRect()
        const cx = cardRect.left + cardRect.width  / 2
        const cy = cardRect.top  + cardRect.height / 2
        const nx = (e.clientX - cx) / (cardRect.width  / 2)
        const ny = (e.clientY - cy) / (cardRect.height / 2)
        this.tiltX += (-ny * this.MAX_TILT - this.tiltX) * 0.12
        this.tiltY += ( nx * this.MAX_TILT - this.tiltY) * 0.12
        this.glare.style.setProperty('--gx', `${(nx + 1) / 2 * 100}%`)
        this.glare.style.setProperty('--gy', `${(ny + 1) / 2 * 100}%`)
      }
    }

    onTouchMove(e: TouchEvent) {
      e.preventDefault()
      if (!this.isInteractive) return
      const rect = this.getBoundingClientRect()
      const t    = e.touches[0]
      this.mouse.x = t.clientX - rect.left
      this.mouse.y = t.clientY - rect.top
      this.mouse.active = true
    }

    onIntersect(e: any) {
      this.isPaused = !e.detail.isIntersecting
      if (this.isPaused) {
        Emitter.off('tick', this.tick, this)
      } else {
        Emitter.on('tick', this.tick, this)
      }
    }

    setSize() {
      this.bounding = { width: this.clientWidth, height: this.clientHeight }
      this.canvas.width  = this.bounding.width
      this.canvas.height = this.bounding.height
      this.cardRect = null
      const cw = this.card?.offsetWidth  || 240
      const ch = this.card?.offsetHeight || 256
      this.dissolveCanvas.width  = cw
      this.dissolveCanvas.height = ch
    }

    spawnParticles() {
      const { width, height } = this.bounding
      this.particles = []
      for (let i = 0; i < this.COUNT; i++) {
        this.particles.push({
          x:  Math.random() * width,
          y:  Math.random() * height,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
          r:  Math.random() * 1.5 + 0.5,
        })
      }
    }

    getColor() {
      return getComputedStyle(this).getPropertyValue('--color-secondary').trim() || '#160000'
    }

    getCardBoundsCanvas() {
      if (!this.cardRect) this.cardRect = this.wrap.getBoundingClientRect()
      const cr = this.cardRect, wrapper = this.getBoundingClientRect()
      const x = cr.left - wrapper.left, y = cr.top - wrapper.top
      return { x, y, w: cr.width, h: cr.height }
    }

    closestPointOnRect(px: number, py: number, rx: number, ry: number, rw: number, rh: number) {
      const cx = Math.max(rx, Math.min(px, rx + rw))
      const cy = Math.max(ry, Math.min(py, ry + rh))
      if (px >= rx && px <= rx + rw && py >= ry && py <= ry + rh) {
        const dl = px - rx, dr = (rx + rw) - px, dt = py - ry, db = (ry + rh) - py
        const min = Math.min(dl, dr, dt, db)
        if (min === dl) return { x: rx,      y: py,      dist: 0 }
        if (min === dr) return { x: rx + rw, y: py,      dist: 0 }
        if (min === dt) return { x: px,      y: ry,      dist: 0 }
        return                 { x: px,      y: ry + rh, dist: 0 }
      }
      return { x: cx, y: cy, dist: Math.hypot(px - cx, py - cy) }
    }

    runTypewriter() {
      if (this.typewriterDone) return
      this.typewriterDone = true
      this.typeName.textContent = ''
      let i = 0
      const interval = setInterval(() => {
        this.typeName.textContent += this.FULL_NAME[i++]
        if (i >= this.FULL_NAME.length) clearInterval(interval)
      }, 50)
    }

    resetTypewriter() {
      this.typewriterDone = false
      this.typeName.textContent = ''
    }

    // ── Pixel dissolve ─────────────────────────────────────────
    // progress 0 → v2 shown (dissolveCanvas is clear, v2 opaque on top)
    // progress 1 → real shown (v2 opacity 0, dissolveCanvas clear)
    // mid-transition: v2 fades + dissolveCanvas draws a checkerboard wipe
    drawDissolve(progress: number) {
      const ctx   = this.dissolveCtx
      const cw    = this.dissolveCanvas.width
      const ch    = this.dissolveCanvas.height
      const pw    = this.PIXEL_SIZE
      const total = this.dissolvePixels.length

      ctx.clearRect(0, 0, cw, ch)
      if (progress <= 0 || progress >= 1) return

      // How many pixels have been "wiped" so far (revealed)
      const wiped = Math.floor(progress * total)

      // Draw v2-colored blocks for pixels NOT yet wiped
      // This keeps v2 visible in those regions even as its CSS opacity drops
      // We sample the v2 image color — but since we can't read pixels easily,
      // we just draw a semi-transparent overlay that transitions:
      // unwiped blocks = keep v2 visible by drawing nothing (v2 still opaque underneath)
      // wiped blocks = draw nothing (real shows through)
      // Edge = red flash

      // Edge band: pixels currently being wiped
      const edgeSize = Math.floor(total * 0.06)
      const edgeStart = wiped
      const edgeEnd   = Math.min(total, wiped + edgeSize)

      ctx.fillStyle = '#F40C3F'
      for (let i = edgeStart; i < edgeEnd; i++) {
        const idx = this.dissolvePixels[i]
        const gx  = (idx % this.dissolveW) * pw
        const gy  = Math.floor(idx / this.dissolveW) * pw
        const t   = (i - edgeStart) / edgeSize
        ctx.globalAlpha = 0.9 * (1 - t)
        ctx.fillRect(gx, gy, pw, pw)
      }
      ctx.globalAlpha = 1
    }

    tick() {
      const { ctx, particles, mouse, bounding } = this
      const { width, height } = bounding
      const baseColor   = this.getColor()
      const accentColor = '#F40C3F'

      ctx.clearRect(0, 0, width, height)
      const cb = this.getCardBoundsCanvas()

      // ── Faster lerp speeds ──
      const target = this.isHoveringCard ? 1 : 0
      this.attractIntensity += (target - this.attractIntensity) * 0.05
      // Speed: 0.08 forward (hover), 0.06 backward (leave) — snappy both ways
      const revealSpeed = this.isHoveringCard ? 0.08 : 0.06
      this.revealProgress += (target - this.revealProgress) * revealSpeed

      // ── Image visibility ──
      // v2: fully opaque at rest, fades as reveal progresses
      // Use a smooth step so it vanishes before the dissolve fully completes
      const v2Opacity = Math.max(0, 1 - this.revealProgress * 1.6)
      this.imgV2.style.opacity = String(v2Opacity)

      // Draw pixel dissolve edge
      this.drawDissolve(this.revealProgress)

      // ── Particles ──
      particles.forEach(p => {
        p.x += p.vx; p.y += p.vy
        if (p.x < 0 || p.x > width)  p.vx *= -1
        if (p.y < 0 || p.y > height) p.vy *= -1

        if (mouse.active) {
          const dx = p.x - mouse.x, dy = p.y - mouse.y
          const dist = Math.hypot(dx, dy)
          if (dist < this.MOUSE_DIST && dist > 0) {
            const force = (this.MOUSE_DIST - dist) / this.MOUSE_DIST
            p.vx += (dx / dist) * force * 0.3
            p.vy += (dy / dist) * force * 0.3
          }
        }

        if (cb && this.attractIntensity > 0.01) {
          const { x: ex, y: ey, dist } = this.closestPointOnRect(p.x, p.y, cb.x, cb.y, cb.w, cb.h)
          if (dist < this.ATTRACT_RADIUS && dist > 2) {
            const falloff = 1 - dist / this.ATTRACT_RADIUS
            const force   = falloff * falloff * this.ATTRACT_FORCE * this.attractIntensity
            const dx = ex - p.x, dy = ey - p.y, d = Math.hypot(dx, dy)
            p.vx += (dx / d) * force; p.vy += (dy / d) * force
          }
          const maxSpeed = 1.5 + this.attractIntensity * 1.2
          const speed = Math.hypot(p.vx, p.vy)
          if (speed > maxSpeed) { p.vx *= maxSpeed / speed; p.vy *= maxSpeed / speed }
        } else {
          const speed = Math.hypot(p.vx, p.vy)
          if (speed > 1.5) { p.vx *= 0.95; p.vy *= 0.95 }
        }
      })

      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x
          const dy = particles[i].y - particles[j].y
          const dist = Math.hypot(dx, dy)
          if (dist < this.CONNECT_DIST) {
            const alpha = (1 - dist / this.CONNECT_DIST) * 0.4
            const mx = (particles[i].x + particles[j].x) / 2
            const my = (particles[i].y + particles[j].y) / 2
            const mdist = mouse.active ? Math.hypot(mx - mouse.x, my - mouse.y) : 999
            const mInfluence = Math.max(0, 1 - mdist / 200)
            ctx.strokeStyle = mInfluence > 0.1
              ? `rgba(244,12,63,${alpha + mInfluence * 0.5})`
              : this.colorWithAlpha(baseColor, alpha)
            ctx.lineWidth = 0.5
            ctx.beginPath()
            ctx.moveTo(particles[i].x, particles[i].y)
            ctx.lineTo(particles[j].x, particles[j].y)
            ctx.stroke()
          }
        }
      }

      if (cb) {
        particles.forEach(p => {
          const { x: ex, y: ey, dist } = this.closestPointOnRect(p.x, p.y, cb.x, cb.y, cb.w, cb.h)
          if (dist < this.CARD_CONNECT_DIST && dist > 0) {
            const t = 1 - dist / this.CARD_CONNECT_DIST
            const alpha = t * (0.55 + this.attractIntensity * 0.3)
            const grad = ctx.createLinearGradient(p.x, p.y, ex, ey)
            grad.addColorStop(0,   this.colorWithAlpha(baseColor, alpha * 0.4))
            grad.addColorStop(0.6, `rgba(244,12,63,${alpha * 0.7})`)
            grad.addColorStop(1,   `rgba(244,12,63,${alpha})`)
            ctx.strokeStyle = grad
            ctx.lineWidth   = 0.5 + t * (0.8 + this.attractIntensity * 0.6)
            ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(ex, ey); ctx.stroke()
          }
        })
      }

      if (mouse.active && mouse.x !== -999) {
        particles.forEach(p => {
          const dist = Math.hypot(p.x - mouse.x, p.y - mouse.y)
          if (dist < this.MOUSE_DIST) {
            const alpha = (1 - dist / this.MOUSE_DIST) * 0.8
            ctx.strokeStyle = `rgba(244,12,63,${alpha})`
            ctx.lineWidth = 1
            ctx.beginPath(); ctx.moveTo(mouse.x, mouse.y); ctx.lineTo(p.x, p.y); ctx.stroke()
          }
        })
        ctx.fillStyle = accentColor; ctx.globalAlpha = 0.9
        ctx.beginPath(); ctx.arc(mouse.x, mouse.y, 3, 0, Math.PI * 2); ctx.fill()
        ctx.globalAlpha = 1
      }

      particles.forEach(p => {
        const dist = mouse.active ? Math.hypot(p.x - mouse.x, p.y - mouse.y) : 999
        const near = Math.max(0, 1 - dist / this.MOUSE_DIST)
        let cardNear = 0
        if (cb) {
          const { dist: cd } = this.closestPointOnRect(p.x, p.y, cb.x, cb.y, cb.w, cb.h)
          cardNear = Math.max(0, 1 - cd / this.CARD_CONNECT_DIST)
        }
        const glow = Math.max(near, cardNear * 0.6)
        ctx.fillStyle   = (near > 0.3 || cardNear > 0.5) ? accentColor : baseColor
        ctx.globalAlpha = 0.5 + glow * 0.5
        ctx.beginPath(); ctx.arc(p.x, p.y, p.r + glow * 2, 0, Math.PI * 2); ctx.fill()
      })
      ctx.globalAlpha = 1

      // Tilt
      const targetIntensity = this.isHoveringCard ? 1 : 0
      this.glitchIntensity += (targetIntensity - this.glitchIntensity) * 0.07
      if (!this.isHoveringCard) {
        this.tiltX += (0 - this.tiltX) * 0.08
        this.tiltY += (0 - this.tiltY) * 0.08
      }
      const scale = 1 + this.glitchIntensity * 0.04
      this.wrap.style.transform = `perspective(900px) rotateX(${this.tiltX}deg) rotateY(${this.tiltY}deg) scale(${scale})`
      this.glare.style.opacity  = String(this.glitchIntensity * 0.4)

      const wasHovered = this.wrap.classList.contains('is-hovered')
      const nowHovered = this.glitchIntensity > 0.05
      if (nowHovered && !wasHovered) {
        this.wrap.classList.add('is-hovered')
        this.runTypewriter()
      } else if (!nowHovered && wasHovered) {
        this.wrap.classList.remove('is-hovered')
        this.resetTypewriter()
      }
    }

    colorWithAlpha(hex: string, alpha: number): string {
      hex = hex.replace('#', '').trim()
      if (hex.length === 3) hex = hex.split('').map(c => c+c).join('')
      const r = parseInt(hex.substring(0,2), 16)
      const g = parseInt(hex.substring(2,4), 16)
      const b = parseInt(hex.substring(4,6), 16)
      return `rgba(${r},${g},${b},${alpha})`
    }
  }

  customElements.define('a-waves', AWaves)
</script>

<style lang="scss">
  a-waves {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    margin: 0;
    padding: 0;
    overflow: hidden;

    canvas.js-canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    }
  }

  .photo-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 2;
  }

  // Transform root — card is sole layout anchor
  .photo-card-wrap {
    position: relative;
    will-change: transform;
    transform: perspective(900px) rotateX(0deg) rotateY(0deg) scale(1);
    transform-style: preserve-3d;
    pointer-events: all;
    // opacity controlled entirely via JS inline style after animation
  }

  // :global so JS classList.add works without Astro scope hash
  :global(.photo-card-wrap.is-entering) {
    animation: card-entry 0.9s cubic-bezier(0.22, 1, 0.36, 1) forwards !important;
    opacity: 1 !important;
  }



  // ── Card ──────────────────────────────────────────────────────

  .photo-card {
    position: relative;
    width: 240px;
    aspect-ratio: 2336 / 2490;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    transition: box-shadow 0.3s ease;
    // Ensure card is never empty/black — real photo always underneath
    background: #111;

    .photo-card-wrap.is-hovered & {
      box-shadow:
        0 16px 48px rgba(244, 12, 63, 0.18),
        0 8px 24px rgba(0, 0, 0, 0.35);
    }

    @include mq(phone) { width: 170px; }
  }

  .photo-img {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    user-select: none;
    pointer-events: none;
    display: block;

    // real photo — always at bottom, always visible
    &--real {
      z-index: 1;
      opacity: 1 !important;
    }

    // v2 — on top by default, fades via JS
    &--v2 {
      z-index: 2;
      opacity: 1;
      transition: none;
    }
  }

  // Dissolve canvas — above both images, draws red edge during wipe
  .photo-dissolve {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    z-index: 3;
    pointer-events: none;
    border-radius: 14px;
  }

  .photo-glare {
    --gx: 50%;
    --gy: 50%;
    position: absolute;
    inset: 0;
    border-radius: 14px;
    z-index: 4;
    opacity: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at var(--gx) var(--gy),
      rgba(255,255,255,0.28) 0%,
      rgba(255,255,255,0.05) 40%,
      transparent 70%
    );
    mix-blend-mode: overlay;
  }

  // ── Animated border ───────────────────────────────────────────

  .photo-border {
    position: absolute;
    top: 0; left: 0;
    width: 240px;
    aspect-ratio: 2336 / 2490;
    border-radius: 16px;
    z-index: 5;
    pointer-events: none;

    @include mq(phone) { width: 170px; }

    &::before {
      content: '';
      position: absolute;
      inset: -2px;
      border-radius: 17px;
      padding: 1.5px;
      background: conic-gradient(
        from var(--angle, 0deg),
        transparent   0deg,
        #F40C3F      60deg,
        #ff6b8a     120deg,
        transparent 180deg,
        transparent 360deg
      );
      -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);
      -webkit-mask-composite: xor;
      mask-composite: exclude;
      animation: border-spin 3s linear infinite;
    }

    &::after {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: 16px;
      border: 1px solid rgba(244, 12, 63, 0.1);
    }
  }

  @property --angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes border-spin {
    to { --angle: 360deg; }
  }

  // ── Terminal ──────────────────────────────────────────────────

  .photo-terminal {
    position: absolute;
    left: calc(100% + 16px);
    top: 50%;
    transform: translateY(-50%) translateX(14px);
    width: 210px;
    background: rgba(6, 0, 0, 0.95);
    border: 1px solid rgba(244, 12, 63, 0.28);
    border-radius: 8px;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: 0.06s;

    .photo-card-wrap.is-hovered & {
      opacity: 1;
      transform: translateY(-50%) translateX(0);
      pointer-events: all;
    }

    @include mq(phone) { display: none; }
  }

  .terminal__header {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 7px 10px 6px;
    border-bottom: 1px solid rgba(244, 12, 63, 0.12);
    background: rgba(244, 12, 63, 0.05);
  }

  .terminal__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
    &--dark { background: rgba(244, 12, 63, 0.18); }
    &--red  { background: #F40C3F; }
  }

  .terminal__title {
    font-family: font-family(mono);
    font-size: 0.58rem;
    color: rgba(244, 12, 63, 0.4);
    letter-spacing: 0.1em;
    margin-left: 4px;
  }

  .terminal__body {
    padding: 11px 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .terminal__line {
    display: flex;
    align-items: baseline;
    gap: 5px;
    font-family: font-family(mono);
    font-size: 0.67rem;
    line-height: 1;
    &--dim    { margin-top: 2px; opacity: 0.4; }
    &--status .terminal__val { animation: status-flicker 4s ease-in-out infinite; }
  }

  .terminal__prompt { color: rgba(255, 80,  80,  0.35); flex-shrink: 0; }
  .terminal__key    { color: rgba(255, 120, 120, 0.7);  letter-spacing: 0.04em; flex-shrink: 0; }
  .terminal__sep    { color: rgba(244, 12,  63,  0.2);  flex-shrink: 0; }

  .terminal__val {
    color: #ff9090;
    letter-spacing: 0.03em;
    &--accent {
      display: flex;
      align-items: center;
      gap: 5px;
      color: #ff9090;
    }
  }

  .terminal__cursor {
    color: #F40C3F;
    animation: cursor-blink 1s step-end infinite;
    font-size: 0.5rem;
  }

  .terminal__comment {
    color: rgba(255, 80, 80, 0.28);
    font-style: italic;
    font-size: 0.6rem;
  }

  .terminal__blink {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #ff6060;
    animation: dot-pulse 1.8s ease-in-out infinite;
    flex-shrink: 0;
    vertical-align: middle;
  }

  .terminal__scanlines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      transparent 3px,
      rgba(0,0,0,0.12) 3px,
      rgba(0,0,0,0.12) 4px
    );
    z-index: 10;
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1;   transform: scale(1); }
    50%       { opacity: 0.3; transform: scale(0.6); }
  }

  @keyframes status-flicker {
    0%, 94%, 100% { opacity: 1; }
    95% { opacity: 0.5; }
    96% { opacity: 1; }
    97% { opacity: 0.2; }
    98% { opacity: 1; }
  }
</style>

<style is:global>
  @keyframes card-entry {
    0% {
      opacity: 0;
      transform: perspective(900px) rotateY(-70deg) translateX(-40px) scale(0.85);
      filter: blur(4px);
    }
    60% {
      filter: blur(0px);
    }
    100% {
      opacity: 1;
      transform: perspective(900px) rotateY(0deg) translateX(0) scale(1);
      filter: blur(0px);
    }
  }
</style>